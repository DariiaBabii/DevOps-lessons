apiVersion: v1
kind: Pod
metadata:
  labels:
    jenkins: kaniko
spec:
  containers:
    - name: kaniko
      image: gcr.io/kaniko-project/executor:latest
      command:
        - sleep
        - "3600"
      volumeMounts:
        - name: aws-creds
          mountPath: /root/.aws
        - name: docker-config
          mountPath: /kaniko/.docker
  volumes:
    - name: aws-creds
      secret:
        secretName: aws-credentials
    - name: docker-config
      configMap:
        name: docker-config
  restartPolicy: Never
